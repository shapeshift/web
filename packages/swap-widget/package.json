{
  "name": "@shapeshiftoss/swap-widget",
  "version": "0.1.0",
  "description": "Embeddable swap widget using ShapeShift API",
  "type": "module",
  "types": "dist/index.d.ts",
  "style": "dist/index.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./style.css": "./dist/index.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist node_modules",
    "build": "rm -rf dist && tsc && tsup",
    "build:demo": "rm -rf dist && vite build",
    "dev": "vite",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@shapeshiftoss/caip": "workspace:^",
    "@shapeshiftoss/types": "workspace:^",
    "@shapeshiftoss/utils": "workspace:^",
    "@xstate/react": "5.0.5",
    "bech32": "^2.0.0",
    "p-queue": "^8.0.1",
    "react-virtuoso": "^4.7.11",
    "xstate": "5.28.0"
  },
  "peerDependencies": {
    "@reown/appkit": "^1.8.17",
    "@reown/appkit-adapter-bitcoin": "^1.8.17",
    "@reown/appkit-adapter-solana": "^1.8.17",
    "@reown/appkit-adapter-wagmi": "^1.8.17",
    "@solana/wallet-adapter-wallets": "^0.19.32",
    "@solana/web3.js": "^1.98.0",
    "@tanstack/react-query": "^5.69.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "viem": "^2.43.5",
    "wagmi": "^3.3.0"
  },
  "peerDependenciesMeta": {
    "@reown/appkit": {
      "optional": true
    },
    "@reown/appkit-adapter-bitcoin": {
      "optional": true
    },
    "@reown/appkit-adapter-solana": {
      "optional": true
    },
    "@reown/appkit-adapter-wagmi": {
      "optional": true
    },
    "@solana/wallet-adapter-wallets": {
      "optional": true
    },
    "@solana/web3.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@reown/appkit": "^1.8.17",
    "@reown/appkit-adapter-bitcoin": "^1.8.17",
    "@reown/appkit-adapter-solana": "^1.8.17",
    "@reown/appkit-adapter-wagmi": "^1.8.17",
    "@solana/wallet-adapter-wallets": "^0.19.32",
    "@solana/web3.js": "1.98.0",
    "@tanstack/react-query": "^5.69.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "jsdom": "28.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "~5.2.2",
    "viem": "2.43.5",
    "vite": "^5.0.0",
    "vite-plugin-node-polyfills": "0.23.0",
    "vitest": "4.0.18",
    "wagmi": "3.3.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
