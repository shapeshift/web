{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @shapeshiftoss/affiliate-dashboard build",
    "watchPatterns": [
      "packages/affiliate-dashboard/**"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter @shapeshiftoss/affiliate-dashboard start",
    "restartPolicyType": "ALWAYS"
  }
}
