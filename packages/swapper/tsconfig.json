{
  "extends": "../../tsconfig.packages.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "moduleResolution": "node",
    "module": "ESNext",
    "baseUrl": "../../",
    "paths": {
      "@cowprotocol/app-data": ["node_modules/@cowprotocol/app-data"],
      "@cowprotocol/app-data/*": ["node_modules/@cowprotocol/app-data/*"],
      "./*": ["./*"]
    }
  },
  "include": ["src/**/*", "src/**/*.json"],
  "exclude": ["dist"],
  "references": [
    { "path": "../caip" },
    { "path": "../chain-adapters" },
    { "path": "../types" },
    { "path": "../utils" }
  ]
}
