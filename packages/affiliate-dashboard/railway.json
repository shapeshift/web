{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": [
      "src/**",
      "package.json",
      "vite.config.ts",
      "index.html",
      "Dockerfile",
      "railway.json"
    ]
  },
  "deploy": {
    "restartPolicyType": "ALWAYS"
  }
}
